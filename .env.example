# =============================================================================
# kinntai 環境変数テンプレート
# このファイルをコピーして `.env` を作成し、各値を埋めてください。
# `.env` は絶対にコミットしないこと。
# =============================================================================

# -----------------------------------------------------------------------------
# アプリ基本設定
# -----------------------------------------------------------------------------
# 動作環境: development / staging / production
NODE_ENV=development

# アプリのベースURL（Auth.js のコールバックURLにも使用）
APP_BASE_URL=http://localhost:3000

# 業務タイムゾーン。基本的に変更しない。
APP_TIMEZONE=Asia/Tokyo

# -----------------------------------------------------------------------------
# データベース（PostgreSQL）
# -----------------------------------------------------------------------------
# 例: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL=postgresql://kinntai:kinntai@localhost:5432/kinntai?schema=public

# Prisma がコネクションプールを使う場合の Direct URL（Supabase 等で使用）
# DIRECT_URL=postgresql://kinntai:kinntai@localhost:5432/kinntai?schema=public

# -----------------------------------------------------------------------------
# 認証（Auth.js / NextAuth）
# -----------------------------------------------------------------------------
# 32文字以上のランダム文字列を生成して指定（例: openssl rand -base64 32）
AUTH_SECRET=replace-with-random-32+chars

# Cookie の secure 設定。production では true を強制
AUTH_COOKIE_SECURE=false

# セッション有効期間（秒）。共有タブレット用は別途短くする想定。
AUTH_SESSION_MAX_AGE=2592000  # 30日

# -----------------------------------------------------------------------------
# 共有タブレット
# -----------------------------------------------------------------------------
# 共有タブレットの暗証番号桁数（変更非推奨）
TABLET_PIN_LENGTH=4

# 共有タブレット用セッション有効期間（秒）。長め推奨。
TABLET_SESSION_MAX_AGE=31536000  # 365日

# -----------------------------------------------------------------------------
# メール送信（パスワードリセット用、MVP 後半で利用）
# -----------------------------------------------------------------------------
MAIL_DRIVER=smtp  # smtp | console（開発時はコンソール出力）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=kinntai

# -----------------------------------------------------------------------------
# ロギング / 監視
# -----------------------------------------------------------------------------
LOG_LEVEL=info  # debug | info | warn | error

# Sentry など外部監視（任意、未設定なら無効）
# SENTRY_DSN=

# -----------------------------------------------------------------------------
# 機能フラグ（Phase 切替用）
# -----------------------------------------------------------------------------
FEATURE_ATTENDANCE_CORRECTION=false   # 打刻修正申請（Phase 2）
FEATURE_LEAVE_REQUEST=false           # 希望休申請（Phase 2）
FEATURE_CSV_EXPORT=false              # CSV エクスポート（Phase 2）
FEATURE_EMPLOYMENT_CONTRACT=false     # 雇用契約書（Future）
FEATURE_CAREER_SUBSIDY=false          # キャリアアップ助成金（Future）

# -----------------------------------------------------------------------------
# 開発補助
# -----------------------------------------------------------------------------
# シード投入時に作る管理者の初期パスワード（開発環境のみ）
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
