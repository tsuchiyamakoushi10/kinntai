// kinntai データベーススキーマ
//
// このファイルは docs/database-design.md §2（MVP）を Prisma DSL に書き下したもの。
// Phase 2 以降（attendance_corrections / leave_requests など）と Future（雇用契約書 等）は
// 必要になってから追加する。
//
// 命名規約（CLAUDE.md §4 準拠）:
//   - DB 側（テーブル / カラム / enum 値）は snake_case / lower_case
//   - TypeScript 側は PascalCase / UPPER_CASE
//   - 上記ギャップは `@map` / `@@map` で吸収する
//
// マルチテナント拡張（docs §6）に備え、主要テーブルへの tenant_id 追加を
// 「列追加で済む」形にしてある（一意制約のスコープは将来 tenant 内に絞る想定）。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL: 通常はコネクションプール経由 (Supabase pgBouncer / port 6543)。
  // DIRECT_URL : マイグレーション・introspection で使う直結 URL (port 5432)。
  //               Supabase Integration が両方を自動で Vercel に流し込む。
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  ADMIN    @map("admin")
  EMPLOYEE @map("employee")

  @@map("user_role")
}

enum Gender {
  MALE   @map("male")
  FEMALE @map("female")
  OTHER  @map("other")

  @@map("gender")
}

enum JobCategory {
  CARE_WORKER    @map("care_worker")
  NURSE          @map("nurse")
  LIFE_COUNSELOR @map("life_counselor")
  CARE_MANAGER   @map("care_manager")
  OFFICE_STAFF   @map("office_staff")
  OTHER          @map("other")

  @@map("job_category")
}

enum EmploymentType {
  FULL_TIME           @map("full_time")
  PART_TIME_INSURED   @map("part_time_insured") // パート（社保あり）。所定時間が長く社会保険加入。
  PART_TIME_UNINSURED @map("part_time_uninsured") // パート（社保なし）。短時間勤務。

  @@map("employment_type")
}

// 在籍状況。retired_at だけだと休職を表現できないため別軸で持つ。
// docs/database-design.md §2.3 を参照。
enum EmploymentStatus {
  ACTIVE   @map("active")
  ON_LEAVE @map("on_leave")
  RETIRED  @map("retired")

  @@map("employment_status")
}

enum WageType {
  HOURLY  @map("hourly")
  MONTHLY @map("monthly")

  @@map("wage_type")
}

enum QualificationType {
  CARE_WORKER        @map("care_worker")
  INITIAL_TRAINING   @map("initial_training")
  PRACTICAL_TRAINING @map("practical_training")
  CHIEF_CARE_WORKER  @map("chief_care_worker")
  NURSE              @map("nurse")
  OTHER              @map("other")

  @@map("qualification_type")
}

enum ShiftKind {
  WORK          @map("work")
  NIGHT_IN      @map("night_in")
  NIGHT_OUT     @map("night_out")
  OFF           @map("off")
  PAID_LEAVE    @map("paid_leave")
  ABSENCE       @map("absence")
  REQUESTED_OFF @map("requested_off")

  @@map("shift_kind")
}

enum AttendanceStatus {
  OPEN      @map("open")
  SUBMITTED @map("submitted")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")

  @@map("attendance_status")
}

enum LeaveGrantType {
  STATUTORY         @map("statutory")
  MANUAL_ADJUSTMENT @map("manual_adjustment")
  CARRY_OVER        @map("carry_over")

  @@map("leave_grant_type")
}

enum DocumentType {
  RESUME                  @map("resume")
  QUALIFICATION_CERT      @map("qualification_cert")
  PRIVACY_CONSENT         @map("privacy_consent")
  EMPLOYMENT_CONTRACT     @map("employment_contract")
  LABOR_CONDITIONS_NOTICE @map("labor_conditions_notice")
  TRAINING_CERT           @map("training_cert")
  OTHER                   @map("other")

  @@map("document_type")
}

enum DocumentAccessAction {
  VIEW     @map("view")
  DOWNLOAD @map("download")
  DELETE   @map("delete")

  @@map("document_access_action")
}

// 研修費の負担区分。docs/database-design.md §2.8 参照。
//   - paid_self: 有料 (本人自己負担)
//   - company_paid: 会社負担 (受講料を会社が支払う)
enum TrainingType {
  PAID_SELF    @map("paid_self")
  COMPANY_PAID @map("company_paid")

  @@map("training_type")
}

// シフト希望の種別。docs/database-design.md §2.10 参照。
enum ShiftPreferenceType {
  REQUESTED_OFF   @map("requested_off")
  PREFERRED_NIGHT @map("preferred_night")
  UNAVAILABLE     @map("unavailable")

  @@map("shift_preference_type")
}

// シフト希望の承認ステータス。docs/database-design.md §2.10 参照。
enum ShiftPreferenceStatus {
  PENDING  @map("pending")
  ACCEPTED @map("accepted")
  REJECTED @map("rejected")

  @@map("shift_preference_status")
}

// 拠点シフト枠の日種区分。docs/database-design.md §2.11 / docs/auto-shift-design.md §3.1 参照。
//   - sunday_holiday は「日曜 + 日本の祝日 + 振替休日」をまとめた区分
enum DayKind {
  WEEKDAY        @map("weekday")
  SATURDAY       @map("saturday")
  SUNDAY_HOLIDAY @map("sunday_holiday")

  @@map("day_kind")
}

// シフト自動作成 run のステータス。docs/auto-shift-design.md §6 参照。
//   - draft     : 自動作成直後 / 微調整中。同月再実行で上書き可
//   - confirmed : 管理者が確定したスナップショット。再実行には「確定取り消し」が必要
enum GenerationRunStatus {
  DRAFT     @map("draft")
  CONFIRMED @map("confirmed")

  @@map("generation_run_status")
}

// 雇用契約の週所定労働時間区分。保険加入判定の根拠で、労働条件通知書にも出力する。
// docs/employment-contract-printable.md §2.2 参照。
enum WeeklyHoursCategory {
  UNDER_20      @map("under_20")
  BETWEEN_20_30 @map("between_20_30")
  BETWEEN_30_40 @map("between_30_40")

  @@map("weekly_hours_category")
}

// 有期雇用特別措置法の対象種別。docs/employment-contract-printable.md §2.2 参照。
enum SpecialMeasureType {
  NONE            @map("none")
  HIGH_SKILL      @map("high_skill")
  POST_RETIREMENT @map("post_retirement")

  @@map("special_measure_type")
}

// =============================================================================
// Models
// =============================================================================

// 拠点
// TODO(multi-tenant): tenant_id を追加する際は (tenant_id, code) の複合一意に切り替える
model Office {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  code      String   @unique
  address   String?
  timezone  String   @default("Asia/Tokyo")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  employees           Employee[]
  shiftPatterns       ShiftPattern[]
  shifts              Shift[]
  attendanceRecords   AttendanceRecord[]
  shiftGenerationRuns ShiftGenerationRun[]
  shiftSetting        OfficeShiftSetting?
  coverageDemands     OfficeCoverageDemand[]

  @@map("offices")
}

// ログインアカウント。employee_id は管理者でも従業員情報を持つ場合があるため nullable。
model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  passwordHash       String    @map("password_hash")
  role               UserRole
  employeeId         String?   @unique @map("employee_id") @db.Uuid
  pinCodeHash        String?   @map("pin_code_hash")
  isActive           Boolean   @default(true) @map("is_active")
  // 初期パスワード (kinntai0000 等) のまま運用に出さないためのフラグ。
  // true の間は layout ガードで /password-change に強制誘導する。
  // 本人が changeMyPassword / confirmPasswordReset で新 PW を設定すると false。
  mustChangePassword Boolean   @default(true) @map("must_change_password")
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee            Employee?            @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  createdShifts       Shift[]              @relation("ShiftCreatedBy")
  updatedShifts       Shift[]              @relation("ShiftUpdatedBy")
  approvedAttendance  AttendanceRecord[]   @relation("AttendanceApprovedBy")
  passwordResetTokens PasswordResetToken[]
  uploadedDocuments   EmployeeDocument[]   @relation("DocumentUploadedBy")
  documentAccessLogs  DocumentAccessLog[]
  createdShiftPrefs   ShiftPreference[]    @relation("ShiftPreferenceCreatedBy")
  reviewedShiftPrefs  ShiftPreference[]    @relation("ShiftPreferenceReviewedBy")
  shiftGenerationRuns ShiftGenerationRun[] @relation("ShiftGenerationRunGeneratedBy")

  @@map("users")
}

// パスワード再設定リクエストごとの 1 回限り使用トークン (S-C-02 / S-C-03)。
//
// - 生トークンは URL に載るので、DB には sha256 ハッシュのみ保存する。
// - 使用済みは used_at で表現。30 分の有効期限と合わせ、リプレイ攻撃を防ぐ。
// - 同一ユーザーが複数回リクエストしても、それぞれ別レコードとして発行する。
//   古いトークンは未使用のまま expires_at で自然に無効になる。
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_reset_tokens")
}

// 従業員。退職後も勤怠データを保持するため、退職は employment_status で表現（物理削除しない）。
// retired_at だけだと休職 (on_leave) を表現できないため、employment_status と併用する。
// TODO(multi-tenant): tenant_id を追加する際は employee_code の一意性を tenant 内に絞る
// 2026-05-26 CSV 一括取り込み (案 A) のため、CSV に値が無い項目を nullable 化。
// 暫定値を入れない方針 (docs/取り込み指示書) に合わせる。投入後 UI から手入力する。
// nullable 化したもの:
//   lastNameKana, firstNameKana, birthDate, officeId, jobCategory, employmentType,
//   joinedAt, hiredAt, weeklyWorkDays, dailyWorkHours, baseWageType, baseWageAmount
model Employee {
  id                         String           @id @default(uuid()) @db.Uuid
  employeeCode               String           @unique @map("employee_code")
  lastName                   String           @map("last_name")
  firstName                  String           @map("first_name")
  lastNameKana               String?          @map("last_name_kana")
  firstNameKana              String?          @map("first_name_kana")
  birthDate                  DateTime?        @map("birth_date") @db.Date
  gender                     Gender?
  phone                      String?
  address                    String?
  officeId                   String?          @map("office_id") @db.Uuid
  jobCategory                JobCategory?     @map("job_category")
  employmentType             EmploymentType?  @map("employment_type")
  joinedAt                   DateTime?        @map("joined_at") @db.Date
  hiredAt                    DateTime?        @map("hired_at") @db.Date
  employmentStatus           EmploymentStatus @default(ACTIVE) @map("employment_status")
  retiredAt                  DateTime?        @map("retired_at") @db.Date
  retirementReason           String?          @map("retirement_reason")
  emergencyContactName       String?          @map("emergency_contact_name")
  emergencyContactRelation   String?          @map("emergency_contact_relation")
  emergencyContactPhone      String?          @map("emergency_contact_phone")
  weeklyWorkDays             Decimal?         @map("weekly_work_days") @db.Decimal(3, 1)
  dailyWorkHours             Decimal?         @map("daily_work_hours") @db.Decimal(4, 2)
  baseWageType               WageType?        @map("base_wage_type")
  baseWageAmount             Int?             @map("base_wage_amount")
  // 月の夜勤希望回数 (自動作成 v2 Phase 2 で優先配置に使用)。null = 希望なし(0 扱い)。
  // shift_constraints.max_night_shifts_per_month (上限) とは別軸 (希望 ≤ 上限 が通常)。
  desiredNightShiftsPerMonth Int?             @map("desired_night_shifts_per_month")
  // 勤務表の手動並び順 (拠点内)。0 = 未設定で、雇用形態順 → 社員コード順にフォールバックする。
  displayOrder               Int              @default(0) @map("display_order")
  notes                      String?
  createdAt                  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  office                Office?                @relation(fields: [officeId], references: [id], onDelete: Restrict)
  user                  User?
  qualifications        Qualification[]
  employmentContracts   EmploymentContract[]
  shifts                Shift[]
  attendanceRecords     AttendanceRecord[]
  paidLeaveGrants       PaidLeaveGrant[]
  paidLeaveConsumptions PaidLeaveConsumption[]
  documents             EmployeeDocument[]
  trainingRecords       TrainingRecord[]
  shiftConstraint       ShiftConstraint?
  shiftPreferences      ShiftPreference[]

  @@index([officeId, employmentStatus])
  @@map("employees")
}

// 雇用契約履歴。employees に持つスナップショット (employment_type / weekly_work_days
// / daily_work_hours / base_wage_*) の履歴元。1 従業員に複数契約を時系列で積む。
// docs/database-design.md §2.5 参照。
// 2026-05-26 CSV 一括取り込み (案 A) のため、CSV に値が無い項目を nullable 化。
// nullable 化したもの:
//   contractStartOn, employmentType, workingHoursPerDay, workingDaysPerWeek,
//   wageType, wageAmount, isRenewable, hasEmploymentInsurance, hasSocialInsurance
model EmploymentContract {
  id                           String               @id @default(uuid()) @db.Uuid
  employeeId                   String               @map("employee_id") @db.Uuid
  contractStartOn              DateTime?            @map("contract_start_on") @db.Date
  contractEndOn                DateTime?            @map("contract_end_on") @db.Date
  employmentType               EmploymentType?      @map("employment_type")
  workingHoursPerDay           Decimal?             @map("working_hours_per_day") @db.Decimal(4, 2)
  workingDaysPerWeek           Decimal?             @map("working_days_per_week") @db.Decimal(3, 1)
  wageType                     WageType?            @map("wage_type")
  wageAmount                   Int?                 @map("wage_amount")
  isRenewable                  Boolean?             @map("is_renewable")
  renewalCount                 Int                  @default(0) @map("renewal_count")
  hasRenewalLimit              Boolean              @default(false) @map("has_renewal_limit")
  renewalLimitCount            Int?                 @map("renewal_limit_count")
  renewalCriteria              String?              @map("renewal_criteria")
  hasEmploymentInsurance       Boolean?             @map("has_employment_insurance")
  hasSocialInsurance           Boolean?             @map("has_social_insurance")
  // NULL = 自動判定値を採用、true/false = 管理者による手動上書き
  retirementAllowanceEligible  Boolean?             @map("retirement_allowance_eligible")
  careerSubsidyTarget          Boolean              @default(false) @map("career_subsidy_target")
  careerSubsidyNotes           String?              @map("career_subsidy_notes")
  // 労働条件通知書 / 雇用契約書 PDF 出力用 (Phase 1-I)。
  // docs/employment-contract-printable.md §2.2 参照。
  workplaceInitial             String?              @map("workplace_initial")
  workplaceScope               String?              @map("workplace_scope")
  jobDescriptionInitial        String?              @map("job_description_initial")
  jobDescriptionScope          String?              @map("job_description_scope")
  weeklyHoursCategory          WeeklyHoursCategory? @map("weekly_hours_category")
  shiftBasedSchedule           Boolean              @default(true) @map("shift_based_schedule")
  hasEarlyEndPossibility       Boolean              @default(true) @map("has_early_end_possibility")
  hasOvertime                  Boolean              @default(false) @map("has_overtime")
  hasBonus                     Boolean              @default(false) @map("has_bonus")
  bonusDescription             String?              @map("bonus_description")
  retirementAllowanceStartText String?              @map("retirement_allowance_start_text")
  specialMeasureType           SpecialMeasureType   @default(NONE) @map("special_measure_type")
  specialMeasureBusinessTitle  String?              @map("special_measure_business_title")
  specialMeasureStartOn        DateTime?            @map("special_measure_start_on") @db.Date
  specialMeasureEndOn          DateTime?            @map("special_measure_end_on") @db.Date
  notes                        String?
  createdAt                    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee   Employee                      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documents  EmployeeDocument[]
  allowances EmploymentContractAllowance[]

  @@index([employeeId, contractStartOn(sort: Desc)])
  @@map("employment_contracts")
}

// 保有資格（介護福祉士 / 初任者研修 など）。キャリアアップ助成金や加算で参照する。
model Qualification {
  id                String            @id @default(uuid()) @db.Uuid
  employeeId        String            @map("employee_id") @db.Uuid
  qualificationType QualificationType @map("qualification_type")
  // 2026-05-26 CSV 取り込みで取得日不明なため nullable 化。
  acquiredOn        DateTime?         @map("acquired_on") @db.Date
  certificateNumber String?           @map("certificate_number")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("qualifications")
}

// シフトパターン定義（早番 / 日勤 / 遅番 / 夜勤 / 明け / 公休 / 有休 / 欠勤 / 希望休）。
// office_id が NULL のものは全拠点共通パターン。
model ShiftPattern {
  id              String    @id @default(uuid()) @db.Uuid
  officeId        String?   @map("office_id") @db.Uuid
  code            String    @unique
  name            String
  shiftKind       ShiftKind @map("shift_kind")
  startTime       DateTime? @map("start_time") @db.Time(0)
  endTime         DateTime? @map("end_time") @db.Time(0)
  crossesMidnight Boolean   @default(false) @map("crosses_midnight")
  breakMinutes    Int       @default(0) @map("break_minutes")
  // 午前 / 午後の在席カウント (0/1)。配置基準を「午前◯名・午後◯名」で評価するため。
  // 正は勤務記号マスター_確定.csv。scripts/sync-coverage.ts で name 名寄せ更新。
  // docs/auto-shift-design-v2.md (案A)。休 / 夜勤 / 厨房 系は 0。
  amCount         Int       @default(0) @map("am_count")
  pmCount         Int       @default(0) @map("pm_count")
  paidLeaveUnits  Decimal   @default(0) @map("paid_leave_units") @db.Decimal(3, 1)
  color           String    @default("#888888")
  sortOrder       Int       @default(0) @map("sort_order")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  office            Office?            @relation(fields: [officeId], references: [id], onDelete: Restrict)
  shifts            Shift[]
  attendanceRecords AttendanceRecord[]

  @@map("shift_patterns")
}

// 月次シフト（勤務表）。office_id は応援勤務に備え employee.office_id と独立に保持。
// generation_run_id が NULL なら手動入力、非 NULL なら自動作成由来 (確定取り消し後も保持)。
// docs/auto-shift-design.md §3.3 参照。
model Shift {
  id              String   @id @default(uuid()) @db.Uuid
  employeeId      String   @map("employee_id") @db.Uuid
  officeId        String   @map("office_id") @db.Uuid
  workDate        DateTime @map("work_date") @db.Date
  shiftPatternId  String   @map("shift_pattern_id") @db.Uuid
  generationRunId String?  @map("generation_run_id") @db.Uuid
  note            String?
  createdBy       String   @map("created_by") @db.Uuid
  updatedBy       String   @map("updated_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee              Employee               @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  office                Office                 @relation(fields: [officeId], references: [id], onDelete: Restrict)
  shiftPattern          ShiftPattern           @relation(fields: [shiftPatternId], references: [id], onDelete: Restrict)
  generationRun         ShiftGenerationRun?    @relation(fields: [generationRunId], references: [id], onDelete: SetNull)
  creator               User                   @relation("ShiftCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  updater               User                   @relation("ShiftUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict)
  paidLeaveConsumptions PaidLeaveConsumption[]

  @@unique([employeeId, workDate])
  @@index([officeId, workDate])
  @@index([generationRunId])
  @@map("shifts")
}

// 打刻実績。1 日 1 レコード。夜勤の work_date は出勤日基準（docs §6 参照）。
model AttendanceRecord {
  id                String           @id @default(uuid()) @db.Uuid
  employeeId        String           @map("employee_id") @db.Uuid
  officeId          String           @map("office_id") @db.Uuid
  workDate          DateTime         @map("work_date") @db.Date
  clockInAt         DateTime?        @map("clock_in_at") @db.Timestamptz(6)
  clockOutAt        DateTime?        @map("clock_out_at") @db.Timestamptz(6)
  shiftPatternId    String?          @map("shift_pattern_id") @db.Uuid
  totalWorkMinutes  Int?             @map("total_work_minutes")
  totalBreakMinutes Int?             @map("total_break_minutes")
  overtimeMinutes   Int?             @map("overtime_minutes")
  nightMinutes      Int?             @map("night_minutes")
  status            AttendanceStatus @default(OPEN)
  approvedBy        String?          @map("approved_by") @db.Uuid
  approvedAt        DateTime?        @map("approved_at") @db.Timestamptz(6)
  note              String?
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  office       Office        @relation(fields: [officeId], references: [id], onDelete: Restrict)
  shiftPattern ShiftPattern? @relation(fields: [shiftPatternId], references: [id], onDelete: SetNull)
  approver     User?         @relation("AttendanceApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  breakRecords BreakRecord[]

  @@unique([employeeId, workDate])
  @@map("attendance_records")
}

// 休憩打刻。進行中の休憩は break_end_at = NULL。
model BreakRecord {
  id                 String    @id @default(uuid()) @db.Uuid
  attendanceRecordId String    @map("attendance_record_id") @db.Uuid
  breakStartAt       DateTime  @map("break_start_at") @db.Timestamptz(6)
  breakEndAt         DateTime? @map("break_end_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  attendanceRecord AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)

  @@index([attendanceRecordId])
  @@map("break_records")
}

// 有給付与履歴。expires_on は付与日 + 2 年（労基法準拠）。
model PaidLeaveGrant {
  id          String         @id @default(uuid()) @db.Uuid
  employeeId  String         @map("employee_id") @db.Uuid
  grantedOn   DateTime       @map("granted_on") @db.Date
  grantedDays Decimal        @map("granted_days") @db.Decimal(4, 1)
  expiresOn   DateTime       @map("expires_on") @db.Date
  grantType   LeaveGrantType @map("grant_type")
  note        String?
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee     Employee               @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  consumptions PaidLeaveConsumption[]

  @@index([employeeId, grantedOn])
  @@map("paid_leave_grants")
}

// 有給消化記録。半休は consumed_days = 0.5。
// 古い付与から消化していくロジックは src/lib/leave/ 配下で扱う。
model PaidLeaveConsumption {
  id            String   @id @default(uuid()) @db.Uuid
  employeeId    String   @map("employee_id") @db.Uuid
  consumedOn    DateTime @map("consumed_on") @db.Date
  consumedDays  Decimal  @map("consumed_days") @db.Decimal(3, 1)
  sourceGrantId String?  @map("source_grant_id") @db.Uuid
  shiftId       String?  @map("shift_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee    Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  sourceGrant PaidLeaveGrant? @relation(fields: [sourceGrantId], references: [id], onDelete: SetNull)
  shift       Shift?          @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@index([employeeId, consumedOn])
  @@map("paid_leave_consumptions")
}

// 従業員に紐付く書類のメタデータ。
// PII を含むためファイル本体は外部ストレージ (storage_key) に置き、DB はメタのみ。
// docs/database-design.md §2.6 参照。
model EmployeeDocument {
  id               String       @id @default(uuid()) @db.Uuid
  employeeId       String       @map("employee_id") @db.Uuid
  documentType     DocumentType @map("document_type")
  title            String
  storageKey       String       @map("storage_key")
  fileName         String       @map("file_name")
  mimeType         String       @map("mime_type")
  fileSize         Int          @map("file_size")
  contractId       String?      @map("contract_id") @db.Uuid
  trainingRecordId String?      @map("training_record_id") @db.Uuid
  expiresOn        DateTime?    @map("expires_on") @db.Date
  uploadedById     String       @map("uploaded_by") @db.Uuid
  uploadedAt       DateTime     @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz(6)
  notes            String?
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee       Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  contract       EmploymentContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  trainingRecord TrainingRecord?     @relation(fields: [trainingRecordId], references: [id], onDelete: SetNull)
  uploadedBy     User                @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  accessLogs     DocumentAccessLog[]

  @@index([employeeId, documentType])
  @@index([expiresOn])
  @@map("employee_documents")
}

// 書類アクセス監査ログ。誰がいつ何を view/download/delete したかを記録する。
// docs/database-design.md §2.7 参照。
model DocumentAccessLog {
  id         String               @id @default(uuid()) @db.Uuid
  documentId String               @map("document_id") @db.Uuid
  userId     String               @map("user_id") @db.Uuid
  action     DocumentAccessAction
  accessedAt DateTime             @default(now()) @map("accessed_at") @db.Timestamptz(6)
  ipAddress  String?              @map("ip_address")
  userAgent  String?              @map("user_agent")

  document EmployeeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([documentId, accessedAt(sort: Desc)])
  @@index([userId, accessedAt(sort: Desc)])
  @@map("document_access_logs")
}

// 研修記録。キャリアアップ助成金 / 処遇改善加算の前提情報として整備する。
// docs/database-design.md §2.8 / requirements.md §4.1 参照。
//   - cost_yen は税込円。会社負担 (COMPANY_PAID) でも実費を記録しておきたいので nullable に留めない方針もあるが、
//     金額不明の場合に NULL を許容する。
//   - 修了証ファイルは EmployeeDocument.trainingRecord で逆引きする。
model TrainingRecord {
  id           String       @id @default(uuid()) @db.Uuid
  employeeId   String       @map("employee_id") @db.Uuid
  trainingName String       @map("training_name")
  trainingType TrainingType @map("training_type")
  costYen      Int?         @map("cost_yen")
  // 2026-05-26 CSV 取り込みで受講日不明なため nullable 化。
  trainedOn    DateTime?    @map("trained_on") @db.Date
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee  Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documents EmployeeDocument[]

  @@index([employeeId, trainedOn(sort: Desc)])
  @@map("training_records")
}

// 個人別シフト制約。1 従業員 1 行 (employee_id unique)。
// docs/database-design.md §2.9 参照。
// - max_*_minutes は分単位で持つ (UI は時間単位に変換)
// - unavailable_days_of_week は 0=日 .. 6=土 の int 配列
model ShiftConstraint {
  id                      String   @id @default(uuid()) @db.Uuid
  employeeId              String   @unique @map("employee_id") @db.Uuid
  maxMonthlyWorkMinutes   Int?     @map("max_monthly_work_minutes")
  maxDailyWorkMinutes     Int?     @map("max_daily_work_minutes")
  maxNightShiftsPerMonth  Int?     @map("max_night_shifts_per_month")
  allowNightShiftOverride Boolean  @default(true) @map("allow_night_shift_override")
  targetMonthlyWorkDays   Int?     @map("target_monthly_work_days")
  annualIncomeCapYen      Int?     @map("annual_income_cap_yen")
  unavailableDaysOfWeek   Int[]    @map("unavailable_days_of_week")
  notes                   String?
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("shift_constraints")
}

// シフト希望 (希望休 / 希望夜勤 / 勤務不可)。
// docs/database-design.md §2.10 参照。
// - 1 従業員 × 1 日 × 1 種別 で一意
// - 本人が作成し、管理者が accepted/rejected で承認する想定 (MVP では accepted 既定運用も可)
model ShiftPreference {
  id             String                @id @default(uuid()) @db.Uuid
  employeeId     String                @map("employee_id") @db.Uuid
  targetDate     DateTime              @map("target_date") @db.Date
  preferenceType ShiftPreferenceType   @map("preference_type")
  status         ShiftPreferenceStatus @default(PENDING)
  note           String?
  createdById    String                @map("created_by") @db.Uuid
  reviewedById   String?               @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?             @map("reviewed_at") @db.Timestamptz(6)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy  User     @relation("ShiftPreferenceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  reviewedBy User?    @relation("ShiftPreferenceReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([employeeId, targetDate, preferenceType])
  @@index([targetDate])
  @@map("shift_preferences")
}

// 拠点別 シフト自動作成 設定 (自動作成 v2)。office と 1:1。
// docs/database-design.md §2.22 / docs/auto-shift-design-v2.md §4.1・§8② 参照。
//   - これまでハードコードしていた調整値を拠点別に外出しする
//   - 行が無い拠点は OFFICE_SHIFT_SETTING_DEFAULTS (shift/office-setting.ts) で扱う
//   - 各列は純粋関数の OfficeShiftSettingValues と 1:1 対応。既定値もそれに合わせる
model OfficeShiftSetting {
  id                            String   @id @default(uuid()) @db.Uuid
  officeId                      String   @unique @map("office_id") @db.Uuid
  // 連勤上限 (全フェーズのハード制約)。
  maxConsecutiveWorkDays        Int      @default(6) @map("max_consecutive_work_days")
  // 月の夜勤上限の既定値 (個人 shift_constraints で上書き可)。
  defaultMaxNightShiftsPerMonth Int      @default(5) @map("default_max_night_shifts_per_month")
  // パート年収上限の既定値 (個人 shift_constraints で上書き可)。
  defaultAnnualIncomeCapYen     Int      @default(1300000) @map("default_annual_income_cap_yen")
  createdAt                     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@map("office_shift_settings")
}

// 拠点別 配置基準 (午前/午後・自動作成 v2 案A)。office × 日種でユニーク。
// docs/database-design.md §2.23 / docs/auto-shift-design-v2.md §10 参照。
//   - 配置基準を「パターン単位 (office_shift_quotas)」ではなく「午前/午後の在席人数」で持つ
//   - 営業日 = am+pm+night_in+night_out > 0 の日種 (専用フラグは持たない)
//   - 相談員は employees.job_category=life_counselor で判定し、午前/午後 各 N 名のチェックに使う
//     (自動配置では強制しない)
model OfficeCoverageDemand {
  id                  String   @id @default(uuid()) @db.Uuid
  officeId            String   @map("office_id") @db.Uuid
  dayKind             DayKind  @map("day_kind")
  amRequired          Int      @default(0) @map("am_required")
  pmRequired          Int      @default(0) @map("pm_required")
  counselorAmRequired Int      @default(0) @map("counselor_am_required")
  counselorPmRequired Int      @default(0) @map("counselor_pm_required")
  nightInRequired     Int      @default(0) @map("night_in_required")
  nightOutRequired    Int      @default(0) @map("night_out_required")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@unique([officeId, dayKind])
  @@map("office_coverage_demands")
}

// シフト自動作成 run の実行履歴。1 (office, target_month) = 1 行 (再実行で上書き)。
// docs/database-design.md §2.12 / docs/auto-shift-design.md §3.2 参照。
//   - status: draft / confirmed。confirmed からは「確定取り消し」で draft に戻す
//   - algorithm_version: 例 "greedy-v1"。改良ごとに更新
//   - stats: jsonb。input/fill/warnings[]/elapsedMs/seed を保持 (スキーマは設計書を参照)
//   - 同月再実行時、generation_run_id を持ち updated_by = generated_by の shifts のみ上書きされる
model ShiftGenerationRun {
  id               String              @id @default(uuid()) @db.Uuid
  officeId         String              @map("office_id") @db.Uuid
  targetMonth      DateTime            @map("target_month") @db.Date
  status           GenerationRunStatus @default(DRAFT)
  algorithmVersion String              @map("algorithm_version")
  generatedById    String              @map("generated_by") @db.Uuid
  generatedAt      DateTime            @default(now()) @map("generated_at") @db.Timestamptz(6)
  confirmedAt      DateTime?           @map("confirmed_at") @db.Timestamptz(6)
  stats            Json                @default("{}")
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  office      Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
  generatedBy User    @relation("ShiftGenerationRunGeneratedBy", fields: [generatedById], references: [id], onDelete: Restrict)
  shifts      Shift[]

  @@unique([officeId, targetMonth])
  @@map("shift_generation_runs")
}

// 会社マスタ (シングルトン)。労働条件通知書 / 雇用契約書 PDF 出力で参照する、
// 全契約共通の条項を保持する。docs/employment-contract-printable.md §2.1 参照。
//
// レコードは常に 1 行。将来マルチテナント化する際は id を tenant_id として
// 再利用し、複数行を許す形に拡張する (列追加で済む形にしてある)。
model CompanyProfile {
  id                     String   @id @default(uuid()) @db.Uuid
  legalName              String   @map("legal_name")
  address                String
  phone                  String
  representativeTitle    String   @map("representative_title")
  representativeName     String   @map("representative_name")
  retirementAge          Int      @map("retirement_age")
  continuedEmploymentAge Int      @map("continued_employment_age")
  resignNoticeDays       Int      @map("resign_notice_days")
  wageCutoffDay          String   @map("wage_cutoff_day")
  wagePaymentDay         String   @map("wage_payment_day")
  wagePaymentMethod      String   @map("wage_payment_method")
  salaryRaisePeriod      String   @map("salary_raise_period")
  overtimeRateUnder60h   Int      @map("overtime_rate_under_60h")
  overtimeRateOver60h    Int      @map("overtime_rate_over_60h")
  overtimeRateWithin     Int      @map("overtime_rate_within")
  holidayLegalRate       Int      @map("holiday_legal_rate")
  nightRate              Int      @map("night_rate")
  breakRuleText          String   @map("break_rule_text")
  workRulesName          String   @map("work_rules_name")
  partTimeWorkRulesName  String   @map("part_time_work_rules_name")
  contactDepartment      String   @map("contact_department")
  contactPersonTitle     String   @map("contact_person_title")
  contactPersonName      String   @map("contact_person_name")
  contactPhone           String   @map("contact_phone")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("company_profile")
}

// 雇用契約に紐づく諸手当 (帳票の イロハニ 4 枠を正規化)。
// docs/employment-contract-printable.md §2.3 参照。
model EmploymentContractAllowance {
  id                String   @id @default(uuid()) @db.Uuid
  contractId        String   @map("contract_id") @db.Uuid
  sortOrder         Int      @map("sort_order")
  name              String
  amountYen         Int      @map("amount_yen")
  calculationMethod String   @map("calculation_method")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  contract EmploymentContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, sortOrder])
  @@map("employment_contract_allowances")
}
